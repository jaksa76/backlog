# push
# ---------------------------------------------------------------------------

push_changes_github() {
	local issues_dir="$1"
	local dry_run="$2"
	local force="$3"
	local snapshot_file="$issues_dir/.snapshot/issues.ndjson"
	require_snapshot "$issues_dir"

	local repo
	repo="$(get_repo_from_manifest "$issues_dir")"

	declare -A snap_data
	while IFS= read -r line; do
		local num
		num="$(jq -r '.number' <<< "$line")"
		[[ -n "$num" ]] || continue
		snap_data["$num"]="$line"
	done < "$snapshot_file"

	# Fetch remote state for conflict detection (skip only when --force, still fetch for --dry-run info)
	declare -A remote_data
	if [[ "$force" == false ]]; then
		echo "Fetching remote state for conflict detection..." >&2
		while IFS= read -r line; do
			local num
			num="$(jq -r '.number' <<< "$line")"
			[[ -n "$num" ]] || continue
			remote_data["$num"]="$line"
		done < <(fetch_remote_ndjson_github "$repo")
	fi

	local created=0 updated=0 closed=0 skipped=0

	# --- New issues (new-issue-* files) ---
	for f in "$issues_dir"/new-issue-*.json; do
		[[ -f "$f" ]] || continue
		local name title body labels assignees payload
		name="$(basename "$f" .json)"
		title="$(jq -r '.title // ""' "$f")"
		body="$(jq -r '.body // ""' "$f")"
		labels="$(jq -c '.labels // []' "$f")"
		assignees="$(jq -c '.assignees // []' "$f")"
		payload="$(jq -n \
			--arg title "$title" \
			--arg body "$body" \
			--argjson labels "$labels" \
			--argjson assignees "$assignees" \
			'{title: $title, body: $body, labels: $labels, assignees: $assignees}')"

		if [[ "$dry_run" == true ]]; then
			printf 'would create  [%s]: %s\n' "$name" "$title"
			((created++)) || true
			continue
		fi

		local real_num
		real_num="$(gh api \
			--method POST \
			-H "Accept: application/vnd.github+json" \
			"/repos/$repo/issues" \
			--input - <<< "$payload" \
			| jq -r '.number')"
		printf 'created  #%s  %s  (was %s)\n' "$real_num" "$title" "$name"
		# Rename file and update number field
		jq --argjson n "$real_num" '.number = $n' "$f" > "$issues_dir/$real_num.json"
		rm "$f"
		((created++)) || true
	done

	# --- Deleted issues (in snapshot but file gone) ---
	for num in "${!snap_data[@]}"; do
		[[ -f "$issues_dir/$num.json" ]] && continue
		local snap_title
		snap_title="$(jq -r '.title // "(no title)"' <<< "${snap_data[$num]}")"

		# Skip if remote also changed since pull (unless --force)
		if [[ "$force" == false && -v remote_data["$num"] ]]; then
			local changed_fields
			changed_fields="$(fields_that_differ "${snap_data[$num]}" "${remote_data[$num]}")"
			if [[ -n "$changed_fields" ]]; then
				printf 'skipped  #%s  %s  (remote changed since pull; use --force to override)\n' "$num" "$snap_title"
				((skipped++)) || true
				continue
			fi
		fi

		if [[ "$dry_run" == true ]]; then
			printf 'would close  #%s: %s\n' "$num" "$snap_title"
			((closed++)) || true
			continue
		fi

		gh api \
			--method PATCH \
			-H "Accept: application/vnd.github+json" \
			"/repos/$repo/issues/$num" \
			-f state=closed > /dev/null
		printf 'closed   #%s  %s\n' "$num" "$snap_title"
		((closed++)) || true
	done

	# --- Modified issues ---
	for num in "${!snap_data[@]}"; do
		local local_file="$issues_dir/$num.json"
		[[ -f "$local_file" ]] || continue

		local snap="${snap_data[$num]}"
		local changed_fields
		changed_fields="$(fields_that_differ "$snap" "$(cat "$local_file")")"
		[[ -n "$changed_fields" ]] || continue  # not modified locally

		local title
		title="$(jq -r '.title // "(no title)"' "$local_file")"

		# Conflict detection: any field changed both locally and remotely to different values?
		if [[ "$force" == false && -v remote_data["$num"] ]]; then
			local remote="${remote_data[$num]}"
			local has_conflict=false
			for field in "${COMPARABLE_FIELDS[@]}"; do
				local snap_val local_val remote_val
				snap_val="$(jq -c --arg f "$field" '.[$f]' <<< "$snap")"
				local_val="$(jq -c --arg f "$field" '.[$f]' <<< "$(cat "$local_file")")"
				remote_val="$(jq -c --arg f "$field" '.[$f]' <<< "$remote")"
				if [[ "$local_val" != "$snap_val" && "$remote_val" != "$snap_val" && "$local_val" != "$remote_val" ]]; then
					has_conflict=true
					break
				fi
			done
			if [[ "$has_conflict" == true ]]; then
				printf 'skipped  #%s  %s  (has conflicts; run conflicts to review or use --force)\n' "$num" "$title"
				((skipped++)) || true
				continue
			fi
		fi

		# Build PATCH payload from fields that differ locally vs snapshot
		local payload="{}"
		local local_json
		local_json="$(cat "$local_file")"
		for field in "${COMPARABLE_FIELDS[@]}"; do
			local snap_val local_val
			snap_val="$(jq -c --arg f "$field" '.[$f]' <<< "$snap")"
			local_val="$(jq -c --arg f "$field" '.[$f]' <<< "$local_json")"
			[[ "$local_val" != "$snap_val" ]] || continue
			payload="$(jq --arg f "$field" --argjson v "$(jq -c --arg f "$field" '.[$f]' <<< "$local_json")" '.[$f] = $v' <<< "$payload")"
		done

		if [[ "$dry_run" == true ]]; then
			printf 'would update  #%s: %s\n' "$num" "$title"
			jq -r 'to_entries[] | "  \(.key): \(.value | tojson)"' <<< "$payload"
			((updated++)) || true
			continue
		fi

		gh api \
			--method PATCH \
			-H "Accept: application/vnd.github+json" \
			"/repos/$repo/issues/$num" \
			--input - <<< "$payload" > /dev/null
		printf 'updated  #%s  %s\n' "$num" "$title"
		((updated++)) || true
	done

	echo ""
	if [[ "$dry_run" == true ]]; then
		printf 'Dry run: %d to create, %d to update, %d to close, %d skipped.\n' "$created" "$updated" "$closed" "$skipped"
	else
		printf 'Done: %d created, %d updated, %d closed, %d skipped.\n' "$created" "$updated" "$closed" "$skipped"
	fi
}

push_changes_jira() {
	local issues_dir="$1"
	local dry_run="$2"
	local force="$3"
	local snapshot_file="$issues_dir/.snapshot/issues.ndjson"
	require_snapshot "$issues_dir"

	local project jql
	project="$(get_jira_project_from_manifest "$issues_dir")"
	jql="$(get_jira_jql_from_manifest "$issues_dir")"

	require_command acli

	declare -A snap_data
	while IFS= read -r line; do
		local num
		num="$(jq -r '.number' <<< "$line")"
		[[ -n "$num" ]] || continue
		snap_data["$num"]="$line"
	done < "$snapshot_file"

	declare -A remote_data
	if [[ "$force" == false ]]; then
		echo "Fetching remote state for conflict detection..." >&2
		while IFS= read -r line; do
			local num
			num="$(jq -r '.number' <<< "$line")"
			[[ -n "$num" ]] || continue
			remote_data["$num"]="$line"
		done < <(fetch_remote_ndjson_jira "$project" "$jql")
	fi

	local created=0 updated=0 closed=0 skipped=0

	# --- New issues (new-issue-* files) ---
	for f in "$issues_dir"/new-issue-*.json; do
		[[ -f "$f" ]] || continue
		local name title
		name="$(basename "$f" .json)"
		title="$(jq -r '.title // ""' "$f")"

		if [[ "$dry_run" == true ]]; then
			printf 'would create  [%s]: %s\n' "$name" "$title"
			((created++)) || true
			continue
		fi

		local create_args=("--project" "$project" "--type" "Task" "--summary" "$title" "--json" "--yes")
		local labels_csv
		labels_csv="$(jq -r '.labels // [] | join(",")' "$f")"
		[[ -z "$labels_csv" ]] || create_args+=("--label" "$labels_csv")
		local assignee
		assignee="$(jq -r '.assignees[0] // ""' "$f")"
		[[ -z "$assignee" ]] || create_args+=("--assignee" "$assignee")

		local desc_file=""
		local body_type
		body_type="$(jq -r '.body | type' "$f")"
		if [[ "$body_type" != "null" ]]; then
			desc_file="$(mktemp)"
			if [[ "$body_type" == "string" ]]; then
				jq -r '.body' "$f" > "$desc_file"
			else
				jq -c '.body' "$f" > "$desc_file"
			fi
			create_args+=("--description-file" "$desc_file")
		fi

		local new_key
		new_key="$(acli jira workitem create "${create_args[@]}" | jq -r '.key // ""')"
		[[ -z "$desc_file" ]] || rm -f "$desc_file"

		if [[ -n "$new_key" ]]; then
			printf 'created  %s  %s  (was %s)\n' "$new_key" "$title" "$name"
			jq --arg k "$new_key" '.number = $k' "$f" > "$issues_dir/$new_key.json"
			rm "$f"
		else
			printf 'created  (key unknown)  %s  (was %s)\n' "$title" "$name"
		fi
		((created++)) || true
	done

	# --- Deleted issues (in snapshot but file gone) ---
	for num in "${!snap_data[@]}"; do
		[[ -f "$issues_dir/$num.json" ]] && continue
		local snap_title
		snap_title="$(jq -r '.title // "(no title)"' <<< "${snap_data[$num]}")"

		# Skip if remote also changed since pull (unless --force)
		if [[ "$force" == false && -v remote_data["$num"] ]]; then
			local changed_fields
			changed_fields="$(fields_that_differ "${snap_data[$num]}" "${remote_data[$num]}")"
			if [[ -n "$changed_fields" ]]; then
				printf 'skipped  %s  %s  (remote changed since pull; use --force to override)\n' "$num" "$snap_title"
				((skipped++)) || true
				continue
			fi
		fi

		if [[ "$dry_run" == true ]]; then
			printf 'would transition  %s: %s  → Done\n' "$num" "$snap_title"
			((closed++)) || true
			continue
		fi

		# Jira has no delete via API; transition to Done as best effort
		if acli jira workitem transition --key "$num" --status "Done" --yes > /dev/null 2>&1; then
			printf 'closed   %s  %s\n' "$num" "$snap_title"
		else
			printf 'warning  %s  %s  (transition to "Done" failed; close manually in Jira)\n' "$num" "$snap_title"
		fi
		((closed++)) || true
	done

	# --- Modified issues ---
	for num in "${!snap_data[@]}"; do
		local local_file="$issues_dir/$num.json"
		[[ -f "$local_file" ]] || continue

		local snap="${snap_data[$num]}"
		local changed_fields
		changed_fields="$(fields_that_differ "$snap" "$(cat "$local_file")")"
		[[ -n "$changed_fields" ]] || continue

		local title
		title="$(jq -r '.title // "(no title)"' "$local_file")"

		# Conflict detection
		if [[ "$force" == false && -v remote_data["$num"] ]]; then
			local remote="${remote_data[$num]}"
			local has_conflict=false
			for field in "${COMPARABLE_FIELDS[@]}"; do
				local snap_val local_val remote_val
				snap_val="$(jq -c --arg f "$field" '.[$f]' <<< "$snap")"
				local_val="$(jq -c --arg f "$field" '.[$f]' <<< "$(cat "$local_file")")"
				remote_val="$(jq -c --arg f "$field" '.[$f]' <<< "$remote")"
				if [[ "$local_val" != "$snap_val" && "$remote_val" != "$snap_val" && "$local_val" != "$remote_val" ]]; then
					has_conflict=true
					break
				fi
			done
			if [[ "$has_conflict" == true ]]; then
				printf 'skipped  %s  %s  (has conflicts; run conflicts to review or use --force)\n' "$num" "$title"
				((skipped++)) || true
				continue
			fi
		fi

		local local_json
		local_json="$(cat "$local_file")"

		# Build edit args; state changes require a separate transition call
		local state_changed=false
		local edit_args=("--key" "$num" "--yes")
		local has_edit_args=false
		local desc_file=""

		for field in "${COMPARABLE_FIELDS[@]}"; do
			local snap_val local_val
			snap_val="$(jq -c --arg f "$field" '.[$f]' <<< "$snap")"
			local_val="$(jq -c --arg f "$field" '.[$f]' <<< "$local_json")"
			[[ "$local_val" != "$snap_val" ]] || continue

			case "$field" in
				state)
					state_changed=true
					;;
				title)
					edit_args+=("--summary" "$(jq -r '.title' "$local_file")")
					has_edit_args=true
					;;
				labels)
					local labels_csv
					labels_csv="$(jq -r '.labels // [] | join(",")' "$local_file")"
					edit_args+=("--labels" "$labels_csv")
					has_edit_args=true
					;;
				assignees)
					local assignee
					assignee="$(jq -r '.assignees[0] // ""' "$local_file")"
					if [[ -n "$assignee" ]]; then
						edit_args+=("--assignee" "$assignee")
					else
						edit_args+=("--remove-assignee")
					fi
					has_edit_args=true
					;;
				body)
					desc_file="$(mktemp)"
					local body_type
					body_type="$(jq -r '.body | type' "$local_file")"
					if [[ "$body_type" == "string" ]]; then
						jq -r '.body // ""' "$local_file" > "$desc_file"
					else
						jq -c '.body' "$local_file" > "$desc_file"
					fi
					edit_args+=("--description-file" "$desc_file")
					has_edit_args=true
					;;
			esac
		done

		if [[ "$dry_run" == true ]]; then
			printf 'would update  %s: %s\n' "$num" "$title"
			[[ "$has_edit_args" == false ]] || printf '  edit: %s\n' "${edit_args[*]}"
			[[ "$state_changed" == false ]] || printf '  transition → %s\n' "$(jq -r '.state' "$local_file")"
			[[ -z "$desc_file" ]] || rm -f "$desc_file"
			((updated++)) || true
			continue
		fi

		[[ "$has_edit_args" == false ]] || acli jira workitem edit "${edit_args[@]}" > /dev/null
		[[ -z "$desc_file" ]] || rm -f "$desc_file"

		if [[ "$state_changed" == true ]]; then
			local new_state
			new_state="$(jq -r '.state' "$local_file")"
			acli jira workitem transition --key "$num" --status "$new_state" --yes > /dev/null
		fi

		printf 'updated  %s  %s\n' "$num" "$title"
		((updated++)) || true
	done

	echo ""
	if [[ "$dry_run" == true ]]; then
		printf 'Dry run: %d to create, %d to update, %d to close, %d skipped.\n' "$created" "$updated" "$closed" "$skipped"
	else
		printf 'Done: %d created, %d updated, %d closed, %d skipped.\n' "$created" "$updated" "$closed" "$skipped"
	fi
}

push_changes() {
	local issues_dir="$1"
	local dry_run="$2"
	local force="$3"
	require_snapshot "$issues_dir"

	local kind
	kind="$(get_source_kind "$issues_dir")"
	case "$kind" in
		github) push_changes_github "$@" ;;
		jira)   push_changes_jira   "$@" ;;
		*)      error "unsupported source kind in manifest: $kind" ;;
	esac
}


main() {
	if [[ $# -lt 1 ]]; then
		usage
		exit 1
	fi

	local command="$1"
	shift

	case "$command" in
		list)
			local out_dir="./backlog"
			while [[ $# -gt 0 ]]; do
				case "$1" in
					--data)
						out_dir="${2:-}"
						shift 2
						;;
					-h|--help)
						usage
						exit 0
						;;
					*)
						error "unknown argument: $1"
						;;
				esac
			done
			list_issues "$out_dir"
			;;
		pull)
			local source="${1:-}"
			[[ -n "$source" ]] || error "missing source after 'pull'"
			shift

			case "$source" in
				github)
					local repo=""
					local out_dir=""
					local timestamp

					while [[ $# -gt 0 ]]; do
						case "$1" in
							--repo)
								repo="${2:-}"
								shift 2
								;;
							--data)
								out_dir="${2:-}"
								shift 2
								;;
							-h|--help)
								usage
								exit 0
								;;
							*)
								error "unknown argument: $1"
								;;
						esac
					done

					[[ -n "$repo" ]] || error "--repo is required (format: owner/repo)"
					if [[ -z "$out_dir" ]]; then
						out_dir="./backlog"
					fi

					pull_github_all_issues "$repo" "$out_dir"
					;;
				jira)
					local project=""
					local jql_override=""
					local out_dir=""

					while [[ $# -gt 0 ]]; do
						case "$1" in
							--project)
								project="${2:-}"
								shift 2
								;;
							--jql)
								jql_override="${2:-}"
								shift 2
								;;
							--data)
								out_dir="${2:-}"
								shift 2
								;;
							-h|--help)
								usage
								exit 0
								;;
							*)
								error "unknown argument: $1"
								;;
						esac
					done

					[[ -n "$project" || -n "$jql_override" ]] || \
						error "--project is required (or provide --jql with an explicit project filter)"
					if [[ -z "$out_dir" ]]; then
						out_dir="./backlog"
					fi

					pull_jira_all_issues "$project" "$jql_override" "$out_dir"
					;;
				*)
					error "unsupported source for pull: $source"
					;;
			esac
			;;
		view)
			local issue_number=""
			if [[ $# -gt 0 && "$1" != --* && "$1" != -* ]]; then
				issue_number="$1"
				shift
			fi
			local out_dir="./backlog"
			while [[ $# -gt 0 ]]; do
				case "$1" in
					--data)
						out_dir="${2:-}"
						shift 2
						;;
					-h|--help)
						usage
						exit 0
						;;
					*)
						error "unknown argument: $1"
						;;
				esac
			done
			if [[ -n "$issue_number" ]]; then
				view_issue "$out_dir" "$issue_number"
			else
				view_all_issues "$out_dir"
			fi
			;;
		edit)
			local user_prompt="${1:-}"
			[[ -n "$user_prompt" ]] || error "missing prompt for 'edit' (e.g.: $SCRIPT_NAME edit \"merge similar issues\")"
			shift
			local out_dir="./backlog"
			while [[ $# -gt 0 ]]; do
				case "$1" in
					--data)
						out_dir="${2:-}"
						shift 2
						;;
					-h|--help)
						usage
						exit 0
						;;
					*)
						error "unknown argument: $1"
						;;
				esac
			done
			edit_issues "$out_dir" "$user_prompt"
			;;
		changes)
			local direction=""
			local out_dir="./backlog"
			while [[ $# -gt 0 ]]; do
				case "$1" in
					--local|--remote)
						direction="$1"
						shift
						;;
					--data)
						out_dir="${2:-}"
						shift 2
						;;
					-h|--help)
						usage
						exit 0
						;;
					*)
						error "unknown argument: $1"
						;;
				esac
			done
			[[ -n "$direction" ]] || error "expected --local or --remote"
			cmd_changes "$out_dir" "$direction"
			;;
		conflicts)
			local out_dir="./backlog"
			while [[ $# -gt 0 ]]; do
				case "$1" in
					--data)
						out_dir="${2:-}"
						shift 2
						;;
					-h|--help)
						usage
						exit 0
						;;
					*)
						error "unknown argument: $1"
						;;
				esac
			done
			show_conflicts "$out_dir"
			;;
		merge)
			local out_dir="./backlog"
			while [[ $# -gt 0 ]]; do
				case "$1" in
					--data)
						out_dir="${2:-}"
						shift 2
						;;
					-h|--help)
						usage
						exit 0
						;;
					*)
						error "unknown argument: $1"
						;;
				esac
			done
			merge_issues "$out_dir"
			;;
		push)
			local out_dir="./backlog"
			local dry_run=false
			local force=false
			while [[ $# -gt 0 ]]; do
				case "$1" in
					--dry-run)
						dry_run=true
						shift
						;;
					--force)
						force=true
						shift
						;;
					--data)
						out_dir="${2:-}"
						shift 2
						;;
					-h|--help)
						usage
						exit 0
						;;
					*)
						error "unknown argument: $1"
						;;
				esac
			done
			push_changes "$out_dir" "$dry_run" "$force"
			;;
		-h|--help|help)
			usage
			;;

		*)
			error "unsupported command: $command"
			;;
	esac
}

main "$@"
