#!/usr/bin/env bash

set -euo pipefail

SCRIPT_NAME="$(basename "$0")"

# Fields compared when computing diffs and conflicts.
# html_url, created_at, updated_at, closed_at, number are not user-editable.
COMPARABLE_FIELDS=("title" "state" "labels" "assignees" "body")

usage() {
	cat <<EOF
Usage:
	$SCRIPT_NAME pull github --repo <owner/repo> [--data <issues_dir>]
	$SCRIPT_NAME pull jira --project <PROJECT_KEY> [--jql <jql>] [--data <issues_dir>]
	$SCRIPT_NAME list [--data <issues_dir>]
	$SCRIPT_NAME view [<issue_number>] [--data <issues_dir>]
	$SCRIPT_NAME edit <prompt> [--data <issues_dir>]
	$SCRIPT_NAME changes --local|--remote [--data <issues_dir>]
	$SCRIPT_NAME conflicts [--data <issues_dir>]
	$SCRIPT_NAME merge [--data <issues_dir>]
	$SCRIPT_NAME push [--dry-run] [--force] [--data <issues_dir>]

Implements:
	pull       pull all issues from a github repository or jira project
	list       list all issues stored locally
	view       view a single issue or all issues in markdown format
	edit       edit issues via an AI agent using a natural language prompt
	changes    list issues changed locally (--local) or remotely since last pull (--remote)
	conflicts  show fields changed both locally and remotely with different values
	merge      apply non-conflicting remote changes to local issue files
	push       push local changes to the source tracker (skips conflicts unless --force)

Local conventions:
	Delete an issue locally by removing its <number>.json file.
	Create a new issue by adding a new-issue-<name>.json file with title/body/labels/assignees.

Examples:
	$SCRIPT_NAME pull github --repo octocat/Hello-World
	$SCRIPT_NAME pull github --repo octocat/Hello-World --data ./my-backlog
	$SCRIPT_NAME pull jira --project MYPROJ
	$SCRIPT_NAME pull jira --project MYPROJ --data ./my-backlog
	$SCRIPT_NAME pull jira --jql "project = MYPROJ AND sprint in openSprints()" --data ./my-backlog
	$SCRIPT_NAME list
	$SCRIPT_NAME list --data ./my-backlog
	$SCRIPT_NAME view
	$SCRIPT_NAME view 42
	$SCRIPT_NAME view 42 --data ./my-backlog
	$SCRIPT_NAME edit "merge similar issues"
	$SCRIPT_NAME edit "close all issues labelled wontfix" --data ./my-backlog
	$SCRIPT_NAME changes --local
	$SCRIPT_NAME changes --remote --data ./my-backlog
	$SCRIPT_NAME conflicts
	$SCRIPT_NAME merge
	$SCRIPT_NAME push --dry-run
	$SCRIPT_NAME push --force
EOF
}

error() {
	echo "error: $*" >&2
	exit 1
}

require_command() {
	local command_name="$1"
	if ! command -v "$command_name" >/dev/null 2>&1; then
		error "required command not found: $command_name"
	fi
}

extract_issue_files() {
	local issues_file="$1"
	local out_dir="$2"

	mkdir -p "$out_dir"

	jq -c '{
		number,
		title,
		state,
		labels: ((.labels // []) | map(.name)),
		assignees: ((.assignees // []) | map(.login)),
		created_at,
		updated_at,
		closed_at,
		html_url,
		body
	}' "$issues_file" | while IFS= read -r compact_issue; do
		issue_number="$(jq -r '.number // empty' <<< "$compact_issue")"
		[[ -n "$issue_number" ]] || continue
		jq '.' <<< "$compact_issue" > "$out_dir/$issue_number.json"
	done
}

pull_github_all_issues() {
	local repo="$1"
	local out_dir="$2"
	local snapshot_dir="$out_dir/.snapshot"
	local issues_file="$snapshot_dir/issues.ndjson"
	local manifest_file="$snapshot_dir/manifest.json"
	local sources_file="$snapshot_dir/sources.json"
	local pulled_at
	local issue_count

	require_command gh

	mkdir -p "$out_dir"
	mkdir -p "$snapshot_dir"

	pulled_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

	gh api \
		--paginate \
		-H "Accept: application/vnd.github+json" \
		"/repos/$repo/issues?state=all&per_page=100&sort=updated&direction=desc" \
		--jq '.[] | select(has("pull_request") | not)' \
		> "$issues_file"

	issue_count="$(wc -l < "$issues_file" | tr -d ' ')"

	extract_issue_files "$issues_file" "$out_dir"

	cat > "$manifest_file" <<EOF
{
	"version": "1",
	"kind": "github",
	"repo": "$repo",
	"pulledAt": "$pulled_at",
	"issueCount": $issue_count,
	"files": {
		"issues": ".snapshot/issues.ndjson",
		"byId": ".."
	}
}
EOF

	cat > "$sources_file" <<EOF
{
	"kind": "github",
	"repo": "$repo",
	"api": "/repos/$repo/issues",
	"query": {
		"state": "all",
		"per_page": 100,
		"sort": "updated",
		"direction": "desc"
	}
}
EOF

	echo "Pulled $issue_count issues from $repo"
	echo "Snapshot written to $snapshot_dir"
	echo "Per-issue files written to $out_dir"
}

# ---------------------------------------------------------------------------
# Jira fetch helpers
# ---------------------------------------------------------------------------

# jq -c -s filter: normalises a slurped JSON array of Jira view objects into
# NDJSON of universal issue records.
JIRA_NORMALIZE_JQ='
	[
		.[] |
		if type == "array" then .[]
		elif (type == "object" and has("issues")) then .issues[]
		elif (type == "object" and has("key")) then .
		else empty
		end
	][] |
	. as $issue |
	{
		number: $issue.key,
		title: ($issue.fields.summary // "(no title)"),
		state: ($issue.fields.status.name // ""),
		labels: ($issue.fields.labels // []),
		assignees: [
			$issue.fields.assignee // null |
			select(. != null) |
			.displayName
		],
		created_at: ($issue.fields.created // null),
		updated_at: ($issue.fields.updated // null),
		closed_at: ($issue.fields.resolutiondate // null),
		html_url: (
			($issue.self // "") |
			if . == "" then ""
			else gsub("/rest/api/[0-9]+/issue/[0-9]+$"; "") + "/browse/" + $issue.key
			end
		),
		body: $issue.fields.description
	}
'

# Fetch all Jira issues matching jql as a JSON array of raw view objects.
# acli search --fields only allows a tiny fixed set, so we use a two-step
# approach: search (paginated) to collect keys, then view per key for full data.
# Outputs a JSON array to stdout; echoes progress to stderr.
fetch_jira_full_json() {
	local jql="$1"
	local keys_file
	keys_file="$(mktemp)"

	acli jira workitem search \
		--jql "$jql" \
		--paginate \
		--json \
		> "$keys_file"

	local keys total i=0
	mapfile -t keys < <(jq -r '.[].key' "$keys_file" 2>/dev/null)
	total="${#keys[@]}"
	rm -f "$keys_file"

	printf '[\n'
	local first=true
	for key in "${keys[@]}"; do
		[[ -n "$key" ]] || continue
		((i++)) || true
		printf 'Fetching %d/%d: %s\n' "$i" "$total" "$key" >&2
		[[ "$first" == true ]] || printf ',\n'
		acli jira workitem view "$key" \
			--fields 'summary,status,labels,assignee,created,updated,resolutiondate,description' \
			--json
		first=false
	done
	printf '\n]\n'
}

pull_jira_all_issues() {
	local project="$1"
	local jql_override="$2"
	local out_dir="$3"
	local snapshot_dir="$out_dir/.snapshot"
	local raw_file="$snapshot_dir/jira-raw.json"
	local issues_file="$snapshot_dir/issues.ndjson"
	local manifest_file="$snapshot_dir/manifest.json"
	local sources_file="$snapshot_dir/sources.json"
	local pulled_at
	local issue_count

	require_command acli
	require_command jq

	mkdir -p "$out_dir"
	mkdir -p "$snapshot_dir"

	pulled_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

	local jql
	if [[ -n "$jql_override" ]]; then
		jql="$jql_override"
	else
		jql="project = \"$project\" ORDER BY created DESC"
	fi

	# Fetch raw Jira issues – saved for auditing and future push support.
	# Uses a 2-step approach: search for keys, then view each key for full fields
	# (acli search --fields only allows a small fixed set).
	echo "Fetching issue list..." >&2
	fetch_jira_full_json "$jql" > "$raw_file"

	# Normalise raw JSON array to universal NDJSON
	jq -c -s "$JIRA_NORMALIZE_JQ" "$raw_file" > "$issues_file"

	issue_count="$(wc -l < "$issues_file" | tr -d ' ')"

	# Write per-issue files in universal format
	while IFS= read -r line; do
		local key
		key="$(jq -r '.number // empty' <<< "$line")"
		[[ -n "$key" ]] || continue
		jq '.' <<< "$line" > "$out_dir/$key.json"
	done < "$issues_file"

	# Manifest (Jira-specific metadata in .snapshot/)
	cat > "$manifest_file" <<EOF
{
	"version": "1",
	"kind": "jira",
	"project": "$project",
	"jql": $(jq -n --arg v "$jql" '$v'),
	"pulledAt": "$pulled_at",
	"issueCount": $issue_count,
	"files": {
		"raw": ".snapshot/jira-raw.json",
		"issues": ".snapshot/issues.ndjson",
		"byKey": ".."
	}
}
EOF

	# Sources (Jira-specific tool/query details in .snapshot/)
	cat > "$sources_file" <<EOF
{
	"kind": "jira",
	"project": "$project",
	"jql": $(jq -n --arg v "$jql" '$v'),
	"tool": "acli",
	"command": "acli jira workitem search"
}
EOF

	echo "Pulled $issue_count issues from Jira project $project"
	echo "Snapshot written to $snapshot_dir"
	echo "Per-issue files written to $out_dir"
}

# invoke_agent sends a system prompt and user prompt to a CLI AI agent.
# Replace the body of this function to use a different agent.
invoke_agent() {
	local system_prompt="$1"
	local user_prompt="$2"
	copilot  --allow-all-tools --add-dir . -p "$(printf '%s\n\n%s' "$system_prompt" "$user_prompt")"
}

edit_issues() {
	local issues_dir="$1"
	local user_prompt="$2"

	[[ -d "$issues_dir" ]] || error "issues directory not found: $issues_dir"

	# Build issues context from all per-issue JSON files
	local issues_context
	issues_context="$(for file in $(ls -v "$issues_dir"/*.json 2>/dev/null); do
		[[ -f "$file" ]] || continue
		cat "$file"
	done)"

	local system_prompt
	system_prompt="You are a backlog management assistant. You help manage GitHub issues stored as JSON files on disk.

Each issue lives at: $issues_dir/<number>.json
Fields: number, title, state, labels, assignees, created_at, updated_at, closed_at, html_url, body
Snapshot metadata (ndjson, manifest, sources) lives in: $issues_dir/.snapshot/

Suggest the shell command(s) needed to fulfil the user request. Operate only on the local files.

Current issues (JSON):
$issues_context"

	invoke_agent "$system_prompt" "$user_prompt"
}

format_issue() {
	local issue_file="$1"

	local number title state state_reason labels assignees created_at updated_at closed_at html_url body
	number="$(jq -r '.number' "$issue_file")"
	title="$(jq -r '.title // "(no title)"' "$issue_file")"
	state="$(jq -r '.state // ""' "$issue_file")"
	state_reason="$(jq -r '.state_reason // ""' "$issue_file")"
	labels="$(jq -r '(.labels // []) | join(", ")' "$issue_file")"
	assignees="$(jq -r '(.assignees // []) | join(", ")' "$issue_file")"
	created_at="$(jq -r '.created_at // ""' "$issue_file")"
	updated_at="$(jq -r '.updated_at // ""' "$issue_file")"
	closed_at="$(jq -r '.closed_at // "null"' "$issue_file")"
	html_url="$(jq -r '.html_url // ""' "$issue_file")"
	# Render body for display: extract text from ADF if needed
	body="$(jq -r '
		.body //  "" |
		if type == "string" then .
		elif (type == "object" and .type == "doc") then
			[.. | objects | select(has("text")) | .text] | join("")
		else tostring
		end
	' "$issue_file")"

	cat <<EOF
# Issue #$number: $title

**State:** $state${state_reason:+ ($state_reason)}
**Labels:** ${labels:-_(none)_}
**Assignees:** ${assignees:-_(none)_}
**Created:** $created_at
**Updated:** $updated_at
**Closed:** $closed_at
**URL:** $html_url

## Description

$body
EOF
}

view_issue() {
	local issues_dir="$1"
	local issue_number="$2"
	local issue_file="$issues_dir/$issue_number.json"

	[[ -f "$issue_file" ]] || error "issue not found: $issue_number"

	format_issue "$issue_file"
}

view_all_issues() {
	local issues_dir="$1"

	[[ -d "$issues_dir" ]] || error "issues directory not found: $issues_dir"

	local first=true
	for file in $(ls -v "$issues_dir"/*.json 2>/dev/null); do
		[[ -f "$file" ]] || continue
		[[ "$first" == true ]] || echo -e "\n---\n"
		format_issue "$file"
		first=false
	done
}

list_issues() {
	local issues_dir="$1"

	[[ -d "$issues_dir" ]] || error "issues directory not found: $issues_dir"

	for file in $(ls -v "$issues_dir"/*.json 2>/dev/null); do
		[[ -f "$file" ]] || continue
		local basename
		basename="$(basename "$file" .json)"
		local id="$basename"
		local title
		title="$(jq -r '.title // "(no title)"' "$file")"
		printf '%s\t%s\n' "$id" "$title"
	done

	for file in "$issues_dir"/new-issue-*.json; do
		[[ -f "$file" ]] || continue
		local basename
		basename="$(basename "$file" .json)"
		local title
		title="$(jq -r '.title // "(no title)"' "$file")"
		printf '%s\t%s\n' "$basename" "$title"
	done
}

# ---------------------------------------------------------------------------
# Snapshot / remote helpers
# ---------------------------------------------------------------------------

get_source_kind() {
	local issues_dir="$1"
	local manifest="$issues_dir/.snapshot/manifest.json"
	[[ -f "$manifest" ]] || error "no snapshot manifest found in $issues_dir/.snapshot/ - run 'pull' first"
	jq -r '.kind' "$manifest"
}

get_repo_from_manifest() {
	local issues_dir="$1"
	local manifest="$issues_dir/.snapshot/manifest.json"
	[[ -f "$manifest" ]] || error "no snapshot manifest found in $issues_dir/.snapshot/ - run 'pull' first"
	jq -r '.repo' "$manifest"
}

get_jira_project_from_manifest() {
	local issues_dir="$1"
	local manifest="$issues_dir/.snapshot/manifest.json"
	[[ -f "$manifest" ]] || error "no snapshot manifest found in $issues_dir/.snapshot/ - run 'pull' first"
	jq -r '.project' "$manifest"
}

get_jira_jql_from_manifest() {
	local issues_dir="$1"
	local manifest="$issues_dir/.snapshot/manifest.json"
	[[ -f "$manifest" ]] || error "no snapshot manifest found in $issues_dir/.snapshot/ - run 'pull' first"
	jq -r '.jql' "$manifest"
}

require_snapshot() {
	local issues_dir="$1"
	[[ -f "$issues_dir/.snapshot/issues.ndjson" ]] || error "no snapshot found in $issues_dir/.snapshot/ - run 'pull' first"
}

# Fetch current issues from GitHub as normalised ndjson (stdout), without modifying snapshot
fetch_remote_ndjson_github() {
	local repo="$1"
	require_command gh
	gh api \
		--paginate \
		-H "Accept: application/vnd.github+json" \
		"/repos/$repo/issues?state=all&per_page=100&sort=updated&direction=desc" \
		--jq '.[] | select(has("pull_request") | not) | {
			number,
			title,
			state,
			labels: ((.labels // []) | map(.name)),
			assignees: ((.assignees // []) | map(.login)),
			created_at,
			updated_at,
			closed_at,
			html_url,
			body
		}'
}

# Fetch current issues from Jira as normalised ndjson (stdout), without modifying snapshot
fetch_remote_ndjson_jira() {
	local project="$1"
	local jql="$2"
	local tmp_raw
	tmp_raw="$(mktemp)"
	require_command acli
	fetch_jira_full_json "$jql" > "$tmp_raw"
	jq -c -s "$JIRA_NORMALIZE_JQ" "$tmp_raw"
	rm -f "$tmp_raw"
}

# Dispatch to the right fetch function based on snapshot manifest kind
fetch_remote_for_dir() {
	local issues_dir="$1"
	local kind
	kind="$(get_source_kind "$issues_dir")"
	case "$kind" in
		github)
			fetch_remote_ndjson_github "$(get_repo_from_manifest "$issues_dir")"
			;;
		jira)
			fetch_remote_ndjson_jira \
				"$(get_jira_project_from_manifest "$issues_dir")" \
				"$(get_jira_jql_from_manifest "$issues_dir")"
			;;
		*)
			error "unsupported source kind in manifest: $kind"
			;;
	esac
}

# Output names of COMPARABLE_FIELDS that differ between two JSON strings
fields_that_differ() {
	local a="$1"
	local b="$2"
	for field in "${COMPARABLE_FIELDS[@]}"; do
		local av bv
		av="$(jq -c --arg f "$field" '.[$f]' <<< "$a")"
		bv="$(jq -c --arg f "$field" '.[$f]' <<< "$b")"
		[[ "$av" == "$bv" ]] || echo "$field"
	done
}

# ---------------------------------------------------------------------------
# changes --local / --remote
# ---------------------------------------------------------------------------

# Outputs: <type>\t<id>\t<title>  (type = new|modified|deleted)
compute_local_changes() {
	local issues_dir="$1"
	local snapshot_file="$issues_dir/.snapshot/issues.ndjson"
	require_snapshot "$issues_dir"

	declare -A snap_data
	while IFS= read -r line; do
		local num
		num="$(jq -r '.number' <<< "$line")"
		[[ -n "$num" ]] || continue
		snap_data["$num"]="$line"
	done < "$snapshot_file"

	# New issues: new-issue-* files
	for f in "$issues_dir"/new-issue-*.json; do
		[[ -f "$f" ]] || continue
		local name title
		name="$(basename "$f" .json)"
		title="$(jq -r '.title // "(no title)"' "$f")"
		printf 'new\t%s\t%s\n' "$name" "$title"
	done

	# Deleted: in snapshot but file no longer present
	for num in "${!snap_data[@]}"; do
		[[ -f "$issues_dir/$num.json" ]] && continue
		local title
		title="$(jq -r '.title // "(no title)"' <<< "${snap_data[$num]}")"
		printf 'deleted\t%s\t%s\n' "$num" "$title"
	done

	# Modified: exists in both but content differs on comparable fields
	for num in "${!snap_data[@]}"; do
		local f="$issues_dir/$num.json"
		[[ -f "$f" ]] || continue
		local changed_fields
		changed_fields="$(fields_that_differ "${snap_data[$num]}" "$(cat "$f")")"
		[[ -n "$changed_fields" ]] || continue
		local title
		title="$(jq -r '.title // "(no title)"' "$f")"
		printf 'modified\t%s\t%s\n' "$num" "$title"
	done
}

# Outputs: <type>\t<number>\t<title>  (type = new|modified|deleted)
# Compares GitHub current state vs snapshot. Does NOT modify snapshot.
compute_remote_changes() {
	local issues_dir="$1"
	local snapshot_file="$issues_dir/.snapshot/issues.ndjson"
	require_snapshot "$issues_dir"

	declare -A snap_data
	while IFS= read -r line; do
		local num
		num="$(jq -r '.number' <<< "$line")"
		[[ -n "$num" ]] || continue
		snap_data["$num"]="$line"
	done < "$snapshot_file"

	declare -A remote_data
	while IFS= read -r line; do
		local num
		num="$(jq -r '.number' <<< "$line")"
		[[ -n "$num" ]] || continue
		remote_data["$num"]="$line"
	done < <(fetch_remote_for_dir "$issues_dir")

	# New remotely (not in snapshot)
	for num in "${!remote_data[@]}"; do
		[[ -v snap_data["$num"] ]] && continue
		local title
		title="$(jq -r '.title // "(no title)"' <<< "${remote_data[$num]}")"
		printf 'new\t%s\t%s\n' "$num" "$title"
	done

	# Deleted remotely
	for num in "${!snap_data[@]}"; do
		[[ -v remote_data["$num"] ]] && continue
		local title
		title="$(jq -r '.title // "(no title)"' <<< "${snap_data[$num]}")"
		printf 'deleted\t%s\t%s\n' "$num" "$title"
	done

	# Modified remotely
	for num in "${!snap_data[@]}"; do
		[[ -v remote_data["$num"] ]] || continue
		local changed_fields
		changed_fields="$(fields_that_differ "${snap_data[$num]}" "${remote_data[$num]}")"
		[[ -n "$changed_fields" ]] || continue
		local title
		title="$(jq -r '.title // "(no title)"' <<< "${remote_data[$num]}")"
		printf 'modified\t%s\t%s\n' "$num" "$title"
	done
}

cmd_changes() {
	local issues_dir="$1"
	local direction="$2"

	[[ -d "$issues_dir" ]] || error "issues directory not found: $issues_dir"

	case "$direction" in
		--local)
			compute_local_changes "$issues_dir" \
				| sort -t$'\t' -k1,1 -k2,2 \
				| awk -F'\t' '{ printf "%-10s  %-30s  %s\n", $1, $2, $3 }'
			;;
		--remote)
			echo "Fetching remote state (this may take a moment)..." >&2
			compute_remote_changes "$issues_dir" \
				| sort -t$'\t' -k1,1 -k2,2 \
				| awk -F'\t' '{ printf "%-10s  %-30s  %s\n", $1, $2, $3 }'
			;;
		*)
			error "expected --local or --remote"
			;;
	esac
}

# ---------------------------------------------------------------------------
# conflicts
# ---------------------------------------------------------------------------

show_conflicts() {
	local issues_dir="$1"
	local snapshot_file="$issues_dir/.snapshot/issues.ndjson"
	require_snapshot "$issues_dir"

	declare -A snap_data
	while IFS= read -r line; do
		local num
		num="$(jq -r '.number' <<< "$line")"
		[[ -n "$num" ]] || continue
		snap_data["$num"]="$line"
	done < "$snapshot_file"

	echo "Fetching remote state..." >&2
	declare -A remote_data
	while IFS= read -r line; do
		local num
		num="$(jq -r '.number' <<< "$line")"
		[[ -n "$num" ]] || continue
		remote_data["$num"]="$line"
	done < <(fetch_remote_for_dir "$issues_dir")

	local any_conflict=false
	for num in "${!snap_data[@]}"; do
		local local_file="$issues_dir/$num.json"
		[[ -f "$local_file" ]] || continue        # locally deleted - not a field conflict
		[[ -v remote_data["$num"] ]] || continue   # remotely deleted - not a field conflict

		local snap="${snap_data[$num]}"
		local remote="${remote_data[$num]}"
		local local_json
		local_json="$(cat "$local_file")"

		local header_printed=false
		for field in "${COMPARABLE_FIELDS[@]}"; do
			local snap_val local_val remote_val
			snap_val="$(jq -c --arg f "$field" '.[$f]' <<< "$snap")"
			local_val="$(jq -c --arg f "$field" '.[$f]' <<< "$local_json")"
			remote_val="$(jq -c --arg f "$field" '.[$f]' <<< "$remote")"

			# Both changed vs snapshot AND diverged from each other
			[[ "$local_val" != "$snap_val" ]] || continue
			[[ "$remote_val" != "$snap_val" ]] || continue
			[[ "$local_val" != "$remote_val" ]] || continue

			if [[ "$header_printed" == false ]]; then
				any_conflict=true
				header_printed=true
				echo "conflict  #$num  $(jq -r '.title' "$local_file")"
			fi
			echo "  field:    $field"
			echo "  snapshot: $snap_val"
			echo "  local:    $local_val"
			echo "  remote:   $remote_val"
		done
		[[ "$header_printed" == false ]] || echo ""
	done

	if [[ "$any_conflict" == false ]]; then
		echo "No conflicts."
	fi
}

# ---------------------------------------------------------------------------
# merge
# ---------------------------------------------------------------------------

merge_issues() {
	local issues_dir="$1"
	local snapshot_file="$issues_dir/.snapshot/issues.ndjson"
	require_snapshot "$issues_dir"

	declare -A snap_data
	while IFS= read -r line; do
		local num
		num="$(jq -r '.number' <<< "$line")"
		[[ -n "$num" ]] || continue
		snap_data["$num"]="$line"
	done < "$snapshot_file"

	echo "Fetching remote state..." >&2
	declare -A remote_data
	while IFS= read -r line; do
		local num
		num="$(jq -r '.number' <<< "$line")"
		[[ -n "$num" ]] || continue
		remote_data["$num"]="$line"
	done < <(fetch_remote_for_dir "$issues_dir")

	local added=0 merged=0 skipped_fields=0
	for num in "${!remote_data[@]}"; do
		local remote="${remote_data[$num]}"
		local local_file="$issues_dir/$num.json"

		# New remote issue: write locally if not already present
		if [[ ! -v snap_data["$num"] ]]; then
			if [[ ! -f "$local_file" ]]; then
				jq '.' <<< "$remote" > "$local_file"
				printf 'added     %s\t%s\n' "$num" "$(jq -r '.title' "$local_file")"
				((added++)) || true
			fi
			continue
		fi

		# Locally deleted - don't restore
		[[ -f "$local_file" ]] || continue

		local snap="${snap_data[$num]}"
		local local_json
		local_json="$(cat "$local_file")"
		local new_json="$local_json"
		local changed=false

		for field in "${COMPARABLE_FIELDS[@]}"; do
			local snap_val local_val remote_val
			snap_val="$(jq -c --arg f "$field" '.[$f]' <<< "$snap")"
			local_val="$(jq -c --arg f "$field" '.[$f]' <<< "$local_json")"
			remote_val="$(jq -c --arg f "$field" '.[$f]' <<< "$remote")"

			# Remote didn't change this field vs snapshot
			[[ "$remote_val" != "$snap_val" ]] || continue

			if [[ "$local_val" != "$snap_val" && "$local_val" != "$remote_val" ]]; then
				# Conflict: skip this field, leave local value intact
				printf 'skipped   field "%s" on #%s (conflict)\n' "$field" "$num"
				((skipped_fields++)) || true
				continue
			fi

			# Apply remote value to local
			new_json="$(jq --arg f "$field" --argjson v "$(jq -c --arg f "$field" '.[$f]' <<< "$remote")" '.[$f] = $v' <<< "$new_json")"
			changed=true
		done

		if [[ "$changed" == true ]]; then
			printf '%s\n' "$new_json" > "$local_file"
			printf 'merged    %s\t%s\n' "$num" "$(jq -r '.title' "$local_file")"
			((merged++)) || true
		fi
	done

	echo ""
	echo "Done: $added added, $merged merged, $skipped_fields field(s) skipped due to conflicts."
}

